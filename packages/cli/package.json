{
  "name": "@open-autocoder/cli",
  "version": "0.1.0",
  "description": "CLI interface for open-autocoder",
  "type": "module",
  "bin": {
    "open-autocoder": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-autocoder/core": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ]
}
